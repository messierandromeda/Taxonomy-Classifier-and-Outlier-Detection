# Secrets (required)
OPENAI_API_KEY=

# Model
OPENAI_MODEL=gpt-5.4-mini

# Tune Processing
BATCH_SIZE=10
GBIF_CONFIDENCE_RESOLVED=80

# Rate limiting
# Tokens per minute for your OpenAI tier. 200000 is the base tier.
OPENAI_TPM=200000

# Dataset schema
# Absolute path inside the container. Defaults to the schema baked into the
# image; set this only when using a different dataset.
# DATASET_SCHEMA=/config/schema.json

# Logging
LOG_LEVEL=INFO