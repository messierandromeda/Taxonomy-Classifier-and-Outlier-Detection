OPENAI_API_KEY=sk-...


# Copy to .env and fill in.

# Secrets (required)
OPENAI_API_KEY=sk-your-key-here

# Models / providers
OPENAI_MODEL=gpt-5.4-mini
# Change if desired
# DEFAULT_MODEL=OPENAI_MODEL

# Tune Processing
BATCH_SIZE=10
GBIF_CONFIDENCE_RESOLVED=80

# Google Earth Engine
GEE_PROJECT=clc-code
GEE_MAP=COPERNICUS/CORINE/V20/100m/2018

# Dataset Schema
DATASET_SCHEMA=./schema.json # Change depending on selected dataset

# Logging
LOG_LEVEL=INFO